@using DfE.EducationProviderRegistry.Web.Mvc.Features.Search.ViewModels

@model SearchRequestViewModel
@{
    ViewData["Title"] = "Search";
}

@{
    var breadcrumbs = new List<Breadcrumb>
    {
        new("Home", "Home", "Index"),
    };
}

@section Breadcrumbs
{
    <partial name="_Breadcrumbs" model="breadcrumbs" />
}


<h1 class="govuk-heading-xl">Search the register</h1>

<form method="post" asp-action="Results">
    <div class="govuk-form-group">
        <label class="govuk-label" for="">
            Establishment or group
        </label>
        <div id="" class="govuk-hint">
            Enter an establishment name, group name, or an ID number
        </div>
        <input class="govuk-input govuk-input--extra-letter-spacing" id="" name="SearchKeywords" type="text" spellcheck="false" aria-describedby="hint-one">
    </div>

    <div class="govuk-form-group">
        <label class="govuk-label" for="">
            Location
        </label>
        <div id="" class="govuk-hint">
            Enter a postcode, local authority, town or city
        </div>
        <input class="govuk-input govuk-input--extra-letter-spacing" id="" name="" type="text" spellcheck="false" aria-describedby="hint-two">
    </div>

    <div class="govuk-form-group">
        <fieldset class="govuk-fieldset">
            <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes">
                <div class="govuk-checkboxes__item">
                    <input class="govuk-checkboxes__input" id="" name="open_establishments" type="checkbox" value="open_establishments">
                    <label class="govuk-label govuk-checkboxes__label" for="organisation">
                        Show open establishments only
                    </label>
                </div>
            </div>
        </fieldset>
    </div>

    <button class="govuk-button" type="submit">Search</button>
</form>