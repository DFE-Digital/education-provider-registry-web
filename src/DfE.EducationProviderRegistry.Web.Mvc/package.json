{
  "name": "dfe.educationproviderregistry.mvc",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "build": "npm run site:sass && npm run govuk:js && npm run govuk:fonts && npm run govuk:images && npm run govuk:manifest && npm run moj:js",
    "site:sass": "sass --style=compressed --load-path=. --load-path=node_modules Styles/site.scss:wwwroot/css/site.css",
    "govuk:js": "copyfiles -f node_modules/govuk-frontend/dist/govuk/govuk-frontend.min.js wwwroot/js",
    "govuk:fonts": "copyfiles -f node_modules/govuk-frontend/dist/govuk/assets/fonts/* wwwroot/assets/fonts",
    "govuk:images": "copyfiles -f node_modules/govuk-frontend/dist/govuk/assets/images/* wwwroot/assets/images",
    "govuk:manifest": "copyfiles -f node_modules/govuk-frontend/dist/govuk/assets/manifest.json wwwroot/assets",
    "moj:js": "copyfiles -f node_modules/@ministryofjustice/frontend/moj/moj-frontend.min.js wwwroot/js"
  },
  "dependencies": {
    "@ministryofjustice/frontend": "^9.0.0",
    "@x-govuk/govuk-prototype-components": "^6.0.0",
    "dfe-frontend": "^2.0.1",
    "govuk-frontend": "^6.1.0"
  },
  "devDependencies": {
    "copyfiles": "^2.4.1",
    "sass": "^1.101.0"
  }
}
