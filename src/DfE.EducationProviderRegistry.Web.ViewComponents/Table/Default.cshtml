@using DfE.EducationProviderRegistry.Web.ViewComponents.Table
@model DfE.EducationProviderRegistry.Web.ViewComponents.Table.GovUkTable

<table class="govuk-table">

    @* Caption *@
    @if (!string.IsNullOrWhiteSpace(Model.Caption))
    {
        string captionClass = GovUkCaptionSizeExtensions.ToCssClass(Model.CaptionSize);

        <caption class="govuk-table__caption @(captionClass)">
            @Model.Caption
        </caption>
    }

    @* Head *@
    @if (Model.Columns.Count > 0)
    {
        <thead class="govuk-table__head">
            <tr class="govuk-table__row">
                @foreach (GovUkTableColumn column in Model.Columns)
                {
                    <th scope="col" class="govuk-table__header @column.Classes">
                        @column.Header
                    </th>
                }
            </tr>
        </thead>
    }

    @* Body *@
    <tbody class="govuk-table__body">

        @for (int rowIndex = 0; rowIndex < Model.Rows.Count; rowIndex++)
        {
            IReadOnlyList<GovUkTableCell> row = Model.Rows[rowIndex];

            <tr class="govuk-table__row">

                @for (int colIndex = 0; colIndex < Model.Columns.Count; colIndex++)
                {
                    GovUkTableColumn column = Model.Columns[colIndex];
                    GovUkTableCell cell = row[colIndex];

                    if (column.IsRowHeader)
                    {
                        <th scope="row" class="govuk-table__header @column.Classes">
                            @if (!string.IsNullOrWhiteSpace(cell.Href))
                            {
                                <a href="@cell.Href" class="govuk-link">
                                    @cell.Text
                                </a>
                            }
                            else
                            {
                                @cell.Text
                            }
                        </th>
                    }
                    else
                    {
                        <td class="govuk-table__cell @(column.IsNumeric ? "govuk-table__cell--numeric" : null)">
                            @if (!string.IsNullOrWhiteSpace(cell.Href))
                            {
                                <a href="@cell.Href">@cell.Text</a>
                            }
                            else
                            {
                                @cell.Text
                            }
                        </td>
                    }
                }

            </tr>
        }

    </tbody>
</table>