@using DfE.EducationProviderRegistry.Web.Mvc.Features.Search.ViewModels
@model (string Title, string FacetKey, FacetViewModel? Facet, List<(string Label, string Value)> Options)

<div class="govuk-form-group">
    <fieldset class="govuk-fieldset">
        <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">
            @Model.Title
        </legend>
        <div class="govuk-checkboxes govuk-checkboxes--small">
            @foreach (var option in Model.Options)
            {
                FacetValueViewModel? facetValue =
                    Model.Facet?.Values
                        .FirstOrDefault(facetValue =>
                            facetValue.Value == option.Value);

                @await Html.PartialAsync(
                    "~/Features/Search/Views/_FiltersComponent.cshtml",
                    (Model.FacetKey, option.Label, option.Value, facetValue)
                )
            }
        </div>
    </fieldset>
</div>
