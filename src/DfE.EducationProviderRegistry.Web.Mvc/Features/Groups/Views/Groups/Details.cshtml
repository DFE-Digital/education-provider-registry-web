@using DfE.EducationProviderRegistry.Web.Mvc.Features.Groups
@model GroupDetailsPageViewModel

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <h1 class="govuk-heading-xl">@Model.Heading</h1>
    </div>
    <div class="govuk-grid-column-one-third">
        <button type="submit" class="govuk-button govuk-button--secondary" data-module="govuk-button">
            Download information
        </button>
    </div>
</div>

<div>
    @await Component.InvokeAsync("GovUkSummaryList", Model.Details.Summary)
    @await Component.InvokeAsync("SharedGovUkTable", Model.Academies.Table)
    @await Component.InvokeAsync("SharedGovUkTable", Model.Governance.TrusteesTable)
    @await Component.InvokeAsync("SharedGovUkTable", Model.Governance.MembersTable)
</div>
