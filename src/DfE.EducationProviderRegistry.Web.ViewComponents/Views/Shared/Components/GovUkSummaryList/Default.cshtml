@using DfE.EducationProviderRegistry.Web.ViewComponents.SummaryList
@model GovUkSummaryList

<dl class="govuk-summary-list">

    @foreach (SummaryListRow row in Model.Rows)
    {
        <div class="govuk-summary-list__row">

            <dt class="govuk-summary-list__key">
                @row.Key
            </dt>

            <dd class="govuk-summary-list__value">

                @if (!string.IsNullOrWhiteSpace(row.Value.Href))
                {
                    <a href="@row.Value.Href" class="govuk-link">
                        @row.Value.Text
                    </a>
                }
                else
                {
                    @row.Value.Text
                }
            </dd>
        </div>
    }

</dl>