@using DfE.EducationProviderRegistry.Web.Mvc.Features.Groups
@using DfE.EducationProviderRegistry.Web.ViewComponents.Tabs
@model GroupDetailsPageViewModel

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <h1 class="govuk-heading-xl">@Model.Heading</h1>
    </div>
    <div class="govuk-grid-column-one-third">
        <button type="submit" class="govuk-button govuk-button--secondary" data-module="govuk-button">
            Download information
        </button>
    </div>
</div>

<div>
    @await Component.InvokeAsync(
        "GovUkTabs",
        new GovUkTabs(
        [
            new Tab(
                id: "details",
                title: "Details",
                contents:
                [
                    new TabContent(
                        viewComponentName: "GovUkSummaryList",
                        model: Model.Details.Summary)
                ]),

            new Tab(
                id: "academies",
                title: Model.Academies.Tab,
                contents:
                [
                    new TabContent(
                        viewComponentName: "SharedGovUkTable",
                        model: Model.Academies.Table)
                ]),

            new Tab(
                id: "governance",
                title: "Governance",
                contents:
                [
                    new TabContent(
                        viewComponentName: "SharedGovUkTable",
                        model: Model.Governance.TrusteesTable),

                    new TabContent(
                        viewComponentName: "SharedGovUkTable",
                        model: Model.Governance.MembersTable)
                ])
        ]))
</div>